rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isVendor() {
      return isAuthenticated() && getUserRole() == 'vendor';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Product media - vendors can upload for their products, anyone can read
    match /product_media/{partId}/{allPaths=**} {
      allow read: if true; // Public read for product browsing
      allow write: if isVendor() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Car images - admins can manage, anyone can read
    match /cars/{carId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // User avatars - users can manage their own, anyone can read
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // User build photos - users can manage their own, public read
    match /builds/{userId}/{buildId}/{allPaths=**} {
      allow read: if true; // Public read for build gallery
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // Review media - users can upload for their reviews
    match /reviews/{userId}/{reviewId}/{allPaths=**} {
      allow read: if true; // Public read for reviews
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // 3D models and AR assets - vendors and admins can manage
    match /3d_models/{partId}/{allPaths=**} {
      allow read: if true; // Public read for 3D previews
      allow write: if isVendor() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // AR assets
    match /ar_assets/{partId}/{allPaths=**} {
      allow read: if true; // Public read for AR previews
      allow write: if isVendor() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Vendor documents (business verification, etc.)
    match /vendor_docs/{vendorId}/{allPaths=**} {
      allow read: if isOwner(vendorId) || isAdmin();
      allow write: if isOwner(vendorId) || isAdmin();
    }
    
    // System assets (logos, banners, etc.) - admin only
    match /system/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Temporary uploads - authenticated users only
    match /temp/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
      // Auto-delete after 24 hours via Cloud Function
    }
    
    // Analytics exports - admin only
    match /exports/{allPaths=**} {
      allow read, write: if isAdmin();
    }
    
    // File size and type restrictions
    function isValidImageUpload() {
      return request.resource.size < 10 * 1024 * 1024 && // 10MB limit
             request.resource.contentType.matches('image/.*');
    }
    
    function isValidVideoUpload() {
      return request.resource.size < 100 * 1024 * 1024 && // 100MB limit
             request.resource.contentType.matches('video/.*');
    }
    
    function isValid3DUpload() {
      return request.resource.size < 50 * 1024 * 1024 && // 50MB limit
             (request.resource.contentType.matches('model/.*') ||
              request.resource.contentType == 'application/octet-stream');
    }
    
    // Apply restrictions to uploads
    match /product_media/{partId}/images/{imageId} {
      allow write: if (isVendor() || isAdmin()) && isValidImageUpload();
    }
    
    match /product_media/{partId}/videos/{videoId} {
      allow write: if (isVendor() || isAdmin()) && isValidVideoUpload();
    }
    
    match /3d_models/{partId}/{modelId} {
      allow write: if (isVendor() || isAdmin()) && isValid3DUpload();
    }
    
    match /avatars/{userId}/{imageId} {
      allow write: if (isOwner(userId) || isAdmin()) && isValidImageUpload();
    }
    
    match /builds/{userId}/{buildId}/{imageId} {
      allow write: if (isOwner(userId) || isAdmin()) && isValidImageUpload();
    }
    
    match /reviews/{userId}/{reviewId}/{mediaId} {
      allow write: if (isOwner(userId) || isAdmin()) && 
                     (isValidImageUpload() || isValidVideoUpload());
    }
  }
}
